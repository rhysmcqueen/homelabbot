# Required
BOT_TOKEN=your_discord_bot_token_here
GUILD_ID=your_guild_id_here

# Optional — defaults shown
OWNER_ID=478640098691514389
MANAGEMENT_ROLE_ID=1127726166137126993
LOG_LEVEL=INFO
DATABASE_PATH=data/homelabbot.db

# Proxmox API (optional — enables /node, /vm, /cluster commands)
PROXMOX_HOST=https://your-proxmox-host:8006
PROXMOX_TOKEN_ID=user@pam!tokenname
PROXMOX_TOKEN_SECRET=your-token-secret-uuid
